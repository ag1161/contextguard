# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Model to use for experiments (default: gpt-4o-mini)
MODEL_NAME=gpt-4o-mini

# Sampling temperature: 0 = deterministic/reproducible, 1 = creative (default: 0.7)
TEMPERATURE=0.7

# Number of runs per prompt — enables stability_score when > 1 (default: 1)
N_RUNS=1
